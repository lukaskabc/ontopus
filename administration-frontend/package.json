{
  "name": "administration-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ci": "npm ci --ignore-scripts",
    "update": "npx npm-check-updates -u -c 7d",
    "dev": "vite",
    "build": "npm run lint && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0 --format unix",
    "lint:fix": "eslint . --fix",
    "prettier:write": "prettier -u -w --ignore-path .gitignore ./src",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@hallysonh/pageable": "1.0.3",
    "@mui/icons-material": "7.3.9",
    "@mui/material": "7.3.9",
    "@mui/x-data-grid": "8.27.5",
    "@mui/x-tree-view": "8.27.2",
    "@rjsf/core": "^6.4.2",
    "@rjsf/mui": "^6.4.2",
    "@rjsf/utils": "^6.4.2",
    "@rjsf/validator-ajv8": "^6.4.2",
    "@toolpad/core": "0.16.0",
    "i18next": "25.8.18",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-chained-backend": "5.0.2",
    "i18next-http-backend": "3.0.2",
    "i18next-localstorage-backend": "4.3.1",
    "i18next-resources-to-backend": "1.2.1",
    "lodash": "4.17.23",
    "preact": "10.29.0",
    "preact-iso": "2.11.1",
    "react-dropzone": "15.0.0",
    "react-i18next": "16.5.8",
    "react-promise-tracker": "2.1.1",
    "sass": "1.98.0",
    "wouter-preact": "3.9.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@preact/preset-vite": "2.10.4",
    "@types/lodash": "4.17.24",
    "eslint": "9.39.4",
    "eslint-formatter-unix": "9.0.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1",
    "vite": "8.0.0",
    "vite-plugin-svgr": "4.5.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": "eslint --max-warnings=0",
    "**/*": "npm run prettier:write"
  }
}
