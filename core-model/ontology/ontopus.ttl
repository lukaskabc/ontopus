@prefix : <http://ontology.lukaskabc.cz/application/ontopus/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix widoco: <https://w3id.org/widoco/vocab#> .
@prefix hydra: <http://www.w3.org/ns/hydra/core#> .
@prefix ontopus-problem: <http://ontology.lukaskabc.cz/application/ontopus/problem/> .
@prefix ontopus: <http://ontology.lukaskabc.cz/application/ontopus/> .
@base <http://ontology.lukaskabc.cz/application/ontopus/> .

<http://ontology.lukaskabc.cz/application/ontopus> rdf:type owl:Ontology ;
                                                    owl:versionIRI <http://ontology.lukaskabc.cz/application/ontopus/1.0-dev> ;
                                                    owl:imports <http://www.w3.org/2002/07/owl> ,
                                                                <http://www.w3.org/1999/02/22-rdf-syntax-ns> ,
                                                                <http://www.w3.org/2000/01/rdf-schema> ,
                                                                <http://www.w3.org/ns/shacl> ,
                                                                <http://w3id.org/widoco/vocab> ,
                                                                <http://rdfs.org/sioc/ns> ,
                                                                <http://www.w3.org/ns/hydra/core> ,
                                                                <https://w3id.org/widoco/vocab/1.0.0> ,
                                                                <http://www.w3.org/ns/dcat3> ;
                                                    <http://purl.org/dc/elements/1.1/creator> "Lukáš Kaňka" ;
                                                    <http://purl.org/vocab/vann/preferredNamespacePrefix> "ontopus" ;
                                                    <http://purl.org/vocab/vann/preferredNamespaceUri> "http://ontology.lukaskabc.cz/application/ontopus/" ;
                                                    sh:suggestedShapesGraph <http://ontology.lukaskabc.cz/application/ontopus/shacl> ;
                                                    rdfs:comment "Ontology Publication Server"@en ;
                                                    rdfs:label "OntoPuS" ;
                                                    owl:versionInfo "Development version 0.0.1"@en .

#################################################################
#    Object Properties
#################################################################

###  http://ontology.lukaskabc.cz/application/ontopus/mappedBy
ontopus:mappedBy rdf:type owl:ObjectProperty ;
                 rdfs:range ontopus:Controller ;
                 rdfs:comment "describes that the resource is mapped by the controller"@en ;
                 rdfs:label "is mapped by"@en .


###  http://ontology.lukaskabc.cz/application/ontopus/ontologyIdentifier
ontopus:ontologyIdentifier rdf:type owl:ObjectProperty ;
                           rdfs:domain ontopus:VersionSeries ;
                           rdfs:range ontopus:VersionArtifact ;
                           rdfs:comment "Identifier of the ontology published in the series"@en ;
                           rdfs:label "Ontology identifier"@en .

###  http://ontology.lukaskabc.cz/application/ontopus/ontologyIdentifier
ontopus:ontologyVersionIdentifier rdf:type owl:ObjectProperty ;
                           rdfs:domain ontopus:VersionArtifact ;
                           rdfs:range rdfs:Resource ;
                           rdfs:comment "Identifier of the ontology version published in the series"@en ;
                           rdfs:label "Ontology version identifier"@en .


###  http://ontology.lukaskabc.cz/application/ontopus/uriMappingType
ontopus:uriMappingType rdf:type owl:ObjectProperty ;
                       rdfs:domain ontopus:UriMapping ;
                       rdfs:range [ rdf:type owl:Class ;
                                    owl:oneOf ( ontopus:OntologyDocument
                                                ontopus:OntologyResource
                                              )
                                  ] ;
                       rdfs:comment "The type of the resource that is being mapped."@en ;
                       rdfs:label "URI Mapping Type"@en .


###  http://ontology.lukaskabc.cz/application/ontopus/hasCondition
ontopus:hasCondition rdf:type owl:ObjectProperty ;
                     rdfs:domain ontopus:WebhookEntry ;
                     rdfs:range ontopus:JsonPointerCondition ;
                     rdfs:comment "A condition of a webhook entry."@en ;
                     rdfs:label "Has condition"@en .


###  http://ontology.lukaskabc.cz/application/ontopus/hasMapping
ontopus:hasMapping rdf:type owl:ObjectProperty ;
                   rdfs:domain ontopus:WebhookEntry ;
                   rdfs:range ontopus:JsonMappingEntry ;
                   rdfs:comment "A mapping of a webhook entry."@en ;
                   rdfs:label "Has mapping"@en .

###  http://ontology.lukaskabc.cz/application/ontopus/hasPrefixDeclaration
ontopus:hasPrefixDeclaration rdf:type owl:ObjectProperty ;
                   rdfs:domain ontopus:VersionArtifact ;
                   rdfs:range sh:PrefixDeclaration ;
                   rdfs:comment "A prefix declaration used by the ontology"@en ;
                   rdfs:label "Has prefix declaration"@en .


#################################################################
#    Data properties
#################################################################

###  http://ontology.lukaskabc.cz/application/ontopus/javaClassName
ontopus:javaClassName rdf:type owl:DatatypeProperty ;
                      rdfs:range xsd:string ;
                      rdfs:comment "The fully qualified name of the Java class"@en ;
                      rdfs:label "Java Class Name"@en .


###  http://ontology.lukaskabc.cz/application/ontopus/password
ontopus:password rdf:type owl:DatatypeProperty ;
                 rdfs:domain ontopus:UserAccount ;
                 rdfs:range xsd:string ;
                 rdfs:comment "A password of an User Account for proving its ownership (authentication)"@en ;
                 rdfs:label "Password"@en .


###  http://ontology.lukaskabc.cz/application/ontopus/serializedImportContext
ontopus:serializedImportContext rdf:type owl:DatatypeProperty ;
                                rdfs:domain ontopus:VersionSeries ;
                                rdfs:range xsd:string ;
                                rdfs:comment "Serialized import process context in JSON string encoded with Base64"@en ;
                                rdfs:label "Serialized import context"@en .

###  http://ontology.lukaskabc.cz/application/ontopus/regexPattern
ontopus:regexPattern rdf:type owl:DatatypeProperty ;
                     rdfs:range xsd:string ;
                     rdfs:comment "A regular expression pattern of a webhook condition or mapping."@en ;
                     rdfs:label "Regular expression pattern"@en .


###  http://ontology.lukaskabc.cz/application/ontopus/secret
ontopus:secret rdf:type owl:DatatypeProperty ;
                     rdfs:range xsd:string ;
                     rdfs:comment "A secret text used for authentication of an application call."@en ;
                     rdfs:label "Secret"@en .

#################################################################
#    Classes
#################################################################

###  http://ontology.lukaskabc.cz/application/ontopus/Controller
ontopus:Controller rdf:type owl:Class ;
                   rdfs:comment "Ontopus Controller class capable of retrieving a resource in a supported media type"@en ;
                   rdfs:label "Ontopus Controller" .


###  http://ontology.lukaskabc.cz/application/ontopus/OntopusCatalog
ontopus:OntopusCatalog rdf:type owl:Class ;
                       rdfs:subClassOf dcat:Catalog ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty dcat:dataset ;
                                         owl:allValuesFrom ontopus:VersionSeries
                                       ] ;
                       rdfs:comment "A catalog of ontology version series served by the ontopus instance"@en ;
                       rdfs:label "Ontology artifact catalog"@en .


###  http://ontology.lukaskabc.cz/application/ontopus/TemporaryContext
ontopus:TemporaryContext rdf:type owl:Class ;
                         rdfs:comment "Temporary GRAPH in a database"@en ;
                         rdfs:label "TemporaryContext"@en .


###  http://ontology.lukaskabc.cz/application/ontopus/ContextToControllerMapping
ontopus:ContextToControllerMapping rdf:type owl:Class ;
                   rdfs:comment "Mapping of a context URI, identifying an ontology, to an Ontopus Controller producing the entity/document in a supported media type."@en ;
                   rdfs:label "URI Mapping"@en .


###  http://ontology.lukaskabc.cz/application/ontopus/UserAccount
ontopus:UserAccount rdf:type owl:Class ;
                    rdfs:subClassOf <http://rdfs.org/sioc/ns#UserAccount> ;
                    rdfs:comment "A User Account in the OntoPuS application"@en ;
                    rdfs:label "User Account"@en .


###  http://ontology.lukaskabc.cz/application/ontopus/VersionArtifact
ontopus:VersionArtifact rdf:type owl:Class ;
                        rdfs:subClassOf dcat:Dataset ;
                        rdfs:comment "An ontology artifact containing a single ontology release (version)"@en ;
                        rdfs:label "Ontology artifact"@en .


###  http://ontology.lukaskabc.cz/application/ontopus/VersionSeries
ontopus:VersionSeries rdf:type owl:Class ;
                      rdfs:subClassOf dcat:DatasetSeries ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty dcat:seriesMember ;
                                        owl:allValuesFrom ontopus:VersionArtifact
                                      ] ;
                      rdfs:comment "Dataset series of ontology artifacts representing different versions of a single ontology"@en ;
                      rdfs:label "Ontology version series"@en .

###  http://ontology.lukaskabc.cz/application/ontopus/Webhook
ontopus:Webhook rdf:type owl:Class ;
                     rdfs:comment "A webhook configuration for a version series."@en ;
                     rdfs:label "Webhook"@en .

###  http://ontology.lukaskabc.cz/application/ontopus/ProblemDetail
ontopus:ProblemDetail rdf:type owl:Class ;
                      rdfs:subClassOf hydra:Error ;
                      rdfs:comment "A runtime error from OntoPuS, used to report information beyond the returned status code."@en ;
                      rdfs:label "Ontopus problem detail"@en .

#################################################################
#    Individuals
#################################################################

###  http://ontology.lukaskabc.cz/application/ontopus/OntologyDocument
ontopus:OntologyDocument rdf:type owl:NamedIndividual ,
                                  <http://xmlns.com/foaf/0.1/Document> ;
                         rdfs:comment "A document describing an ontology"@en ;
                         rdfs:label "Ontology Document"@en .


###  http://ontology.lukaskabc.cz/application/ontopus/OntologyResource
ontopus:OntologyResource rdf:type owl:NamedIndividual ,
                                rdfs:Resource ;
                       rdfs:comment "A thing that participates in an ontology"@en ;
                       rdfs:label "Ontology Entity"@en .

ontopus-problem:access-denied rdf:type ontopus:ProblemDetail ;
                             rdfs:label "Access Denied"@en ;
                             rdfs:comment "User is not authorized to access the requested resource."@en .

<http://ontology.lukaskabc.cz/application/ontopus/problem/access-denied/invalid-signature> rdf:type ontopus:ProblemDetail ;
                                              rdfs:subClassOf ontopus-problem:access-denied ;
                                              rdfs:label "Invalid signature"@en ;
                                              rdfs:comment "A required signature is missing or invalid"@en .

ontopus-problem:file-processing rdf:type ontopus:ProblemDetail ;
                             rdfs:label "File processing error"@en ;
                             rdfs:comment "An error during file processing"@en .

<http://ontology.lukaskabc.cz/application/ontopus/problem/file-processing/unsupported-format> rdf:type ontopus:ProblemDetail ;
                                              rdfs:subClassOf ontopus-problem:file-processing ;
                                              rdfs:label "Unsupported format"@en ;
                                              rdfs:comment "File processing failed because of unsupported format"@en .

<http://ontology.lukaskabc.cz/application/ontopus/problem/file-processing/serialization> rdf:type ontopus:ProblemDetail ;
                                              rdfs:subClassOf ontopus-problem:file-processing ;
                                              rdfs:label "Serialization error"@en ;
                                              rdfs:comment "An error occurred during data serialization."@en .

ontopus-problem:mapping rdf:type ontopus:ProblemDetail ;
                             rdfs:label "Resource mapping error"@en ;
                             rdfs:comment "An error during resource URI mapping"@en .

<http://ontology.lukaskabc.cz/application/ontopus/problem/mapping/not-supported> rdf:type ontopus:ProblemDetail ;
                                              rdfs:subClassOf ontopus-problem:mapping ;
                                              rdfs:label "Unsupported resource mapping"@en ;
                                              rdfs:comment "The controller does not support the requested mapping of the resource"@en .

ontopus-problem:internal-error rdf:type ontopus:ProblemDetail ;
                             rdfs:label "Internal Error"@en ;
                             rdfs:comment "An internal error occurred. System administrator should be notified and server logs analyzed."@en .

<http://ontology.lukaskabc.cz/application/ontopus/problem/internal-error/initialization> rdf:type ontopus:ProblemDetail ;
                                              rdfs:subClassOf ontopus-problem:internal-error ;
                                              rdfs:label "Initialization error"@en ;
                                              rdfs:comment "The controller does not support the requested mapping of the resource."@en .

<http://ontology.lukaskabc.cz/application/ontopus/problem/internal-error/serialization> rdf:type ontopus:ProblemDetail ;
                                              rdfs:subClassOf ontopus-problem:internal-error ;
                                              rdfs:label "Serialization error"@en ;
                                              rdfs:comment "An error occurred during serialization or deserialization of an object."@en .

ontopus-problem:not-found rdf:type ontopus:ProblemDetail ;
                             rdfs:label "Not found"@en ;
                             rdfs:comment "The requested resource was not found on the server."@en .

ontopus-problem:persistence rdf:type ontopus:ProblemDetail ;
                             rdfs:label "Persistence error"@en ;
                             rdfs:comment "A persistence operation failed."@en .

ontopus-problem:validation rdf:type ontopus:ProblemDetail ;
