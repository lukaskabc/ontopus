@prefix : <http://ontology.lukaskabc.cz/application/ontopus#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ontopus: <http://ontology.lukaskabc.cz/application/ontopus#> .
@base <http://ontology.lukaskabc.cz/application/ontopus#> .

<http://ontology.lukaskabc.cz/application/ontopus> rdf:type owl:Ontology ;
                                                    owl:versionIRI <http://ontology.lukaskabc.cz/application/ontopus/1.0-dev> ;
                                                    owl:imports <http://rdfs.org/sioc/ns> ,
                                                                <https://www.w3.org/ns/dcat3> ;
                                                    <http://purl.org/dc/elements/1.1/creator> "Lukáš Kaňka" ;
                                                    <http://purl.org/vocab/vann/preferredNamespacePrefix> "ontopus" ;
                                                    <http://purl.org/vocab/vann/preferredNamespaceUri> "http://ontology.lukaskabc.cz/application/ontopus#" ;
                                                    rdfs:comment "Ontology Publication Server"@en ;
                                                    rdfs:label "OntoPuS" ;
                                                    owl:versionInfo "Development version 0.0.1"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#versionIRI
owl:versionIRI rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2002/07/owl#versionInfo
owl:versionInfo rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://ontology.lukaskabc.cz/application/ontopus#containsOntologyArtifact
ontopus:containsOntologyArtifact rdf:type owl:ObjectProperty ;
                                   rdfs:subPropertyOf dcat:dataset ;
                                   rdfs:domain ontopus:OntologyArtifactCatalog ;
                                   rdfs:range ontopus:OntologyArtifact ;
                                   rdfs:comment "An ontology artifact that is listed in the catalog"@en ;
                                   rdfs:label "contains ontology artifact"@en .


###  http://ontology.lukaskabc.cz/application/ontopus#hasOntologyDistribution
ontopus:hasOntologyDistribution rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf dcat:distribution ;
                                rdfs:domain ontopus:OntologyArtifact ;
                                rdfs:range ontopus:OntologyDistribution .


#################################################################
#    Data properties
#################################################################

###  http://ontology.lukaskabc.cz/application/ontopus#password
ontopus:password rdf:type owl:DatatypeProperty ;
                 rdfs:domain ontopus:UserAccount ;
                 rdfs:range xsd:string ;
                 rdfs:comment "A password of an User Account for proving its ownership (authentication)"@en ;
                 rdfs:label "Password"@en .


#################################################################
#    Classes
#################################################################

###  http://ontology.lukaskabc.cz/application/ontopus#OntologyArtifact
ontopus:OntologyArtifact rdf:type owl:Class ;
                         rdfs:subClassOf dcat:Dataset ;
                         rdfs:comment "An ontology artifact"@en ;
                         rdfs:label "Ontology artifact"@en .


###  http://ontology.lukaskabc.cz/application/ontopus#OntologyArtifactCatalog
ontopus:OntologyArtifactCatalog rdf:type owl:Class ;
                                rdfs:subClassOf dcat:Catalog ;
                                rdfs:comment "A catalog of ontology artifacts served by the ontopus instance"@en ;
                                rdfs:label "Ontology artifact catalog"@en .


###  http://ontology.lukaskabc.cz/application/ontopus#OntologyDistribution
ontopus:OntologyDistribution rdf:type owl:Class ;
                             rdfs:subClassOf dcat:Distribution ;
                             rdfs:label "Ontology distribution"@en .


###  http://ontology.lukaskabc.cz/application/ontopus#TemporaryContext
ontopus:TemporaryContext rdf:type owl:Class ;
                         rdfs:comment "Temporary GRAPH in a database"@en ;
                         rdfs:label "TemporaryContext"@en .


###  http://ontology.lukaskabc.cz/application/ontopus#UserAccount
ontopus:UserAccount rdf:type owl:Class ;
                    rdfs:subClassOf <http://rdfs.org/sioc/ns#UserAccount> ;
                    rdfs:comment "A User Account in the OntoPuS application"@en ;
                    rdfs:label "User Account"@en .


