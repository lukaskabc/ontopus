{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "$translationRoot": "ontopus.plugin.git.importForm",
  "properties": {
    "repositoryUrl": {
      "type": "string",
      "format": "uri"
    },
    "branch": {
      "type": "string"
    },
    "authText": {
      "type": "string"
    },
    "username": {
      "type": "string"
    },
    "password": {
      "type": "string"
    }
  },
  "required": [
    "repositoryUrl"
  ],
  "dependencies": {
    "password": [
      "username"
    ],
    "username": [
      "password"
    ]
  }
}
