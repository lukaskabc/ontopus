      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "uri": {
                  "type": ["null","string"]
                },
                "jsonPointer": {
                  "type": "string"
                },
                "regex": {
                  "type": "string"
                }
              },
              "required": ["jsonPointer", "regex"]
            }
          },
          "mappings": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "uri": {
                  "type": ["null","string"]
                },
                "sourcePointer": {
                  "type": "string"
                },
                "targetPointer": {
                  "type": "string"
                },
                "valuePattern": {
                  "type": "string"
                }
              },
              "required": ["sourcePointer", "targetPointer"]
            }
          }
        }
      }
    }
  },
  "required": ["webhooks"]
}

